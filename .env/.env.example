# Dispatch local data directory. Use an OneDrive-synced path if cross-device sync is needed.
DISPATCH_DATA_DIR=~/.dispatch/

# GitHub personal access token used by Dispatch to read repository content.
# In GitHub Actions, store this secret as TOKEN and map it to GITHUB_TOKEN at runtime.
GITHUB_TOKEN=

# Autopilot executor API key used to authenticate dispatch requests.
AUTOPILOT_API_KEY=

# Autopilot API endpoint URL used for executor dispatch calls.
AUTOPILOT_API_ENDPOINT=http://localhost:8000/agent/run

# Public webhook callback URL for receiving async executor responses (for example, ngrok).
AUTOPILOT_WEBHOOK_URL=

# Optional OpenAI API key for LLM-assisted payload generation.
OPENAI_API_KEY=

# Optional OpenAI model used for LLM-assisted payload generation.
OPENAI_MODEL=gpt-4o
